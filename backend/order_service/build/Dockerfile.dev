FROM golang:1.26

WORKDIR /app

COPY ./backend/order_service/go.mod ./backend/order_service/go.mod

COPY ./backend/devpack/go.mod ./backend/devpack/go.mod

RUN go work init

RUN go work use ./backend/order_service

RUN go work use ./backend/devpack

RUN go mod download

COPY ./backend/order_service/ ./backend/order_service

COPY ./backend/devpack/ ./backend/devpack

CMD ["go", "run", "./backend/order_service/cmd/api/main.go"]
