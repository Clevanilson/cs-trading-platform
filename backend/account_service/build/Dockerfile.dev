FROM golang:1.26

WORKDIR /app

COPY ./backend/account_service/go.mod ./backend/account_service/go.mod

COPY ./backend/devpack/go.mod ./backend/devpack/go.mod

RUN go work init

RUN go work use ./backend/account_service

RUN go work use ./backend/devpack

RUN go mod download

COPY ./backend/account_service/ ./backend/account_service

COPY ./backend/devpack/ ./backend/devpack

CMD ["go", "run", "./backend/account_service/cmd/api/main.go"]
