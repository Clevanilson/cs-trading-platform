# Browser-facing API URLs should stay on same-origin proxy paths.
# Local `npm run dev` and Docker dev both route these through Vite.
VITE_ACCOUNT_API_URL=/api/account
VITE_ORDER_API_URL=/api/order

# Local proxy targets when the frontend runs outside Docker.
ACCOUNT_PROXY_TARGET=http://localhost:3001
ORDER_PROXY_TARGET=http://localhost:3002

# Docker dev overrides the proxy targets to Compose service DNS names.
# ACCOUNT_PROXY_TARGET=http://cs-trading-platform-account-service:3001
# ORDER_PROXY_TARGET=http://cs-trading-platform-order-service:3002
